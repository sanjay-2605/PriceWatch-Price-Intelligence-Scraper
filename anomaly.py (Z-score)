import numpy as np

def detect_anomaly(prices):
    if len(prices) < 2:
        return "Not enough data"

    mean = np.mean(prices)
    std = np.std(prices)

    latest = prices[-1]
    z = (latest - mean) / std if std != 0 else 0

    if abs(z) > 2:
        return f"Anomaly detected (z={round(z,2)})"
    return "Normal"
